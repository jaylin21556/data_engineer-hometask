{
  "name": "data-platform-cost-governed",
  "definition": {
    "autotermination_minutes": {
      "type": "range",
      "maxValue": 15,
      "defaultValue": 10
    },
    "cluster_type": {
      "type": "fixed",
      "value": "job",
      "hidden": true
    },
    "node_type_id": {
      "type": "allowlist",
      "values": [
        "m5.large",
        "m5.xlarge",
        "m5.2xlarge",
        "c5.large",
        "c5.xlarge",
        "c5.2xlarge",
        "r5.large",
        "r5.xlarge"
      ],
      "defaultValue": "m5.large"
    },
    "driver_node_type_id": {
      "type": "allowlist",
      "values": [
        "m5.large",
        "m5.xlarge"
      ],
      "defaultValue": "m5.large"
    },
    "num_workers": {
      "type": "range",
      "minValue": 1,
      "maxValue": 8,
      "defaultValue": 2
    },
    "spark_version": {
      "type": "regex",
      "pattern": ".*-lts-.*",
      "defaultValue": "14.3.x-scala2.12"
    },
    "instance_pool_id": {
      "type": "unlimited",
      "isOptional": false
    },
    "custom_tags.App": {
      "type": "fixed",
      "value": "data-platform"
    },
    "custom_tags.CostCenter": {
      "type": "fixed",
      "value": "1234"
    },
    "spark_conf.spark.databricks.cluster.profile": {
      "type": "forbidden",
      "hidden": true
    }
  }
}
